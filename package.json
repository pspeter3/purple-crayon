{
  "name": "purple-crayon",
  "version": "0.0.1",
  "description": "Creative coding library for personal projects",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./utils.js": "./dist/utils.js"
  },
  "scripts": {
    "build": "wireit",
    "fix": "wireit",
    "fix:format": "wireit",
    "fix:lint": "wireit",
    "test": "wireit",
    "test:format": "wireit",
    "test:lint": "wireit",
    "test:spec": "wireit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pspeter3/purple-crayon.git"
  },
  "author": "pspeter3",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pspeter3/purple-crayon/issues"
  },
  "homepage": "https://github.com/pspeter3/purple-crayon#readme",
  "devDependencies": {
    "@types/node": "^18.11.9",
    "@typescript-eslint/eslint-plugin": "^5.43.0",
    "@typescript-eslint/parser": "^5.43.0",
    "eslint": "^8.28.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4",
    "wireit": "^0.8.0"
  },
  "wireit": {
    "build": {
      "command": "tsc --build --pretty",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "dist/**/*.{js,d.ts}",
        ".tsbuildinfo"
      ]
    },
    "fix": {
      "dependencies": [
        "fix:format"
      ]
    },
    "fix:format": {
      "command": "prettier --cache --write '.github/**/*' 'src/**/*' README.md",
      "dependencies": [
        "fix:lint"
      ]
    },
    "fix:lint": {
      "command": "eslint --fix --cache --cache-location .eslintcache 'src/**/*'"
    },
    "test": {
      "dependencies": [
        "test:format",
        "test:lint",
        "test:spec"
      ]
    },
    "test:format": {
      "command": "prettier --cache --check '.github/**/*' 'src/**/*' README.md",
      "files": [
        ".github/**/*",
        "src/**/*",
        "README.md",
        "node_modules/.cache/prettier/.prettier-cache"
      ],
      "output": []
    },
    "test:lint": {
      "command": "eslint --color --cache --cache-location .eslintcache 'src/**/*'",
      "files": [
        "src/**/*",
        ".eslintcache"
      ],
      "output": []
    },
    "test:spec": {
      "command": "node --test dist/",
      "files": [
        "dist/**.js"
      ],
      "output": [],
      "dependencies": [
        "build"
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "root": true
  },
  "prettier": {
    "tabWidth": 4
  }
}
