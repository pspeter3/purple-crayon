{
  "name": "purple-crayon",
  "version": "0.0.0",
  "description": "Creative coding library for personal projects",
  "type": "module",
  "scripts": {
    "compile": "wireit",
    "format": "wireit",
    "spec": "wireit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pspeter3/purple-crayon.git"
  },
  "author": "pspeter3",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pspeter3/purple-crayon/issues"
  },
  "homepage": "https://github.com/pspeter3/purple-crayon#readme",
  "devDependencies": {
    "@types/node": "^18.11.9",
    "@typescript-eslint/eslint-plugin": "^5.43.0",
    "@typescript-eslint/parser": "^5.43.0",
    "eslint": "^8.28.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.4",
    "wireit": "^0.8.0"
  },
  "wireit": {
    "format": {
      "command": "prettier --write 'src/**/*' README.md",
      "files": [
        "src/**/*",
        "README.md"
      ],
      "output": []
    },
    "compile": {
      "command": "tsc --build --pretty",
      "clean": "if-file-deleted",
      "files": [
        "src/**/*.ts",
        "tsconfig.json"
      ],
      "output": [
        "lib/**.{js,dts}",
        ".tsbuildinfo"
      ]
    },
    "spec": {
      "command": "node --test lib/",
      "files": [
        "lib/**.js"
      ],
      "output": [],
      "dependencies": [
        "compile"
      ]
    }
  }
}
